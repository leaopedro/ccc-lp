# Notion integration
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Redirect targets for /whatsapp and /instagram endpoints
WHATSAPP_URL=https://wa.me/5541900000000
INSTAGRAM_URL=https://instagram.com/casacarclub.curitiba

# Instagram handle displayed in the Hero (without @, e.g. casacarclub.curitiba)
VITE_INSTAGRAM_HANDLE=casacarclub.curitiba

# Comma-separated list of form field IDs to hide (optional, defaults to none hidden)
# Available IDs: nome, email, whatsapp, carro, interesse
# Example: VITE_DISABLED_FIELDS=carro,interesse
VITE_DISABLED_FIELDS=
